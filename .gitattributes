# Normalize line endings — checked-in text is LF; Windows tooling still works.
* text=auto eol=lf

# Windows-native scripts keep CRLF
*.bat  text eol=crlf
*.ps1  text eol=crlf
*.cmd  text eol=crlf

# Treat these as binary (never touch line endings / never diff)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.wav  binary
*.flac binary
*.mp3  binary
*.pt   binary
*.pth  binary
*.bin  binary
*.safetensors binary
